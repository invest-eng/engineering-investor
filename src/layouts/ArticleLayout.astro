---
import BaseLayout from './BaseLayout.astro';
import Badge from '../components/ui/Badge.astro';
import Disclaimer from '../components/ui/Disclaimer.astro';
import Button from '../components/ui/Button.astro';
import { SITE } from '../config';
import { url } from '../utils/url';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  readingTime: number;
  category: string;
  premium?: boolean;
  image?: string;
}

const { title, description, pubDate, readingTime, category, premium = false, image } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('sl-SI', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(pubDate);
---

<BaseLayout title={title} description={description} article={true}>
  <div class="article-page">
    <div class="container">

      <!-- Breadcrumb -->
      <nav class="article-breadcrumb" aria-label="Pot do strani">
        <a href={url('/')} class="article-breadcrumb__link">Domov</a>
        <span class="article-breadcrumb__sep" aria-hidden="true">/</span>
        <a href={url('/analize')} class="article-breadcrumb__link">Analize</a>
        <span class="article-breadcrumb__sep" aria-hidden="true">/</span>
        <span class="article-breadcrumb__current" aria-current="page">{title}</span>
      </nav>

      <div class="article-layout">
        <!-- Main content -->
        <article class="article-main">
          <!-- Article header -->
          <header class="article-header fade-in">
            <div class="article-header__meta">
              <Badge category={category} />
              {premium && (
                <span class="article-header__premium">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                  Premium vsebina
                </span>
              )}
            </div>

            <h1 class="article-header__title">{title}</h1>
            <p class="article-header__description">{description}</p>

            <div class="article-header__byline">
              <div class="article-header__author">
                <div class="article-header__author-avatar" aria-hidden="true">EI</div>
                <div>
                  <span class="article-header__author-name">{SITE.name}</span>
                  <div class="article-header__dates">
                    <time datetime={pubDate.toISOString()}>{formattedDate}</time>
                    <span aria-hidden="true">·</span>
                    <span>{readingTime} min branja</span>
                  </div>
                </div>
              </div>
            </div>
          </header>

          <!-- Hero image -->
          {image && (
            <div class="article-hero-image">
              <img src={image} alt={title} loading="lazy" />
            </div>
          )}

          <!-- Article divider -->
          <hr class="article-divider" />

          <!-- Article body -->
          <div class="article-body prose fade-in">
            <slot />
          </div>

          <!-- Footer -->
          <footer class="article-footer fade-in">
            <Disclaimer />

            <div class="article-footer__share">
              <p class="article-footer__share-label">Delite analizo</p>
              <a
                href={`https://x.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(SITE.url + '/analize/')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="article-footer__share-btn"
                aria-label="Deli na X"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
                Deli na X
              </a>
            </div>

            <div class="article-footer__cta">
              <Button href={url('/analize')} variant="ghost">
                ← Vse analize
              </Button>
            </div>
          </footer>
        </article>

        <!-- Sidebar -->
        <aside class="article-sidebar">
          <!-- Table of contents placeholder -->
          <div class="article-sidebar__widget">
            <h3 class="article-sidebar__widget-title">Vsebina</h3>
            <ul class="article-toc" id="article-toc">
              <!-- Filled by JS -->
            </ul>
          </div>

          <!-- CTA widget -->
          <div class="article-sidebar__widget article-sidebar__cta">
            <div class="article-sidebar__cta-badge">Newsletter</div>
            <h3 class="article-sidebar__cta-title">Ostani obveščen</h3>
            <p class="article-sidebar__cta-desc">Prejmi nove analize na email.</p>
            <a href={url('/#email-signup')} class="article-sidebar__cta-btn">Naroči se</a>
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .article-page {
    padding: var(--space-xl) 0 var(--space-3xl);
  }

  /* Breadcrumb */
  .article-breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .article-breadcrumb__link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .article-breadcrumb__link:hover {
    color: var(--color-text);
  }

  .article-breadcrumb__sep {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
  }

  .article-breadcrumb__current {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 300px;
  }

  /* Layout */
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-2xl);
    align-items: start;
  }

  /* Article main */
  .article-main {
    min-width: 0;
  }

  /* Header */
  .article-header {
    margin-bottom: var(--space-xl);
  }

  .article-header__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .article-header__premium {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-xs);
    font-weight: 600;
    color: #D97706;
    background: #FFF7ED;
    border-radius: var(--radius-full);
    padding: 3px 10px;
  }

  [data-theme="dark"] .article-header__premium {
    background: #2A1800;
    color: #FDBA74;
  }

  .article-header__title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-lg);
  }

  .article-header__description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }

  .article-header__byline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .article-header__author {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .article-header__author-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--color-accent);
    color: white;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 700;
    flex-shrink: 0;
  }

  .article-header__author-name {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .article-header__dates {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* Hero image */
  .article-hero-image {
    margin: var(--space-xl) 0 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .article-hero-image img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 640px) {
    .article-hero-image img {
      height: 220px;
    }
  }

  .article-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-xl) 0;
  }

  /* Body */
  .article-body {
    margin-bottom: var(--space-2xl);
  }

  /* Footer */
  .article-footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .article-footer__share {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .article-footer__share-label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    margin: 0;
  }

  .article-footer__share-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    background: var(--color-surface-hover);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.5rem 1rem;
    text-decoration: none;
    transition: background-color var(--transition-fast), border-color var(--transition-fast);
  }

  .article-footer__share-btn:hover {
    background: var(--color-surface);
    border-color: var(--color-border-strong);
  }

  .article-footer__cta {
    display: flex;
    justify-content: flex-start;
  }

  /* Sidebar */
  .article-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + var(--space-xl));
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .article-sidebar__widget {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }

  .article-sidebar__widget-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: var(--space-md);
  }

  .article-toc {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .article-toc li a {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    line-height: 1.4;
    transition: color var(--transition-fast);
    display: block;
    padding: 2px 0;
    padding-left: var(--space-md);
    border-left: 2px solid var(--color-border);
  }

  .article-toc li a:hover {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
  }

  /* Sidebar CTA */
  .article-sidebar__cta {
    background: var(--color-accent-bg);
    border-color: var(--color-accent-border);
  }

  .article-sidebar__cta-badge {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .article-sidebar__cta-title {
    font-size: var(--text-base);
    font-weight: 700;
    margin-bottom: var(--space-xs);
  }

  .article-sidebar__cta-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
    line-height: 1.6;
  }

  .article-sidebar__cta-btn {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 500;
    color: white;
    background: var(--color-accent);
    border-radius: var(--radius-sm);
    padding: 0.5rem 1rem;
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }

  .article-sidebar__cta-btn:hover {
    background: var(--color-accent-hover);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .article-layout {
      grid-template-columns: 1fr;
    }

    .article-sidebar {
      position: static;
      order: -1;
    }

    .article-sidebar__widget:first-child {
      display: none;
    }
  }
</style>

<script is:inline>
  // Build table of contents from h2 headings
  const headings = document.querySelectorAll('.article-body h2');
  const toc = document.getElementById('article-toc');

  if (toc && headings.length > 0) {
    headings.forEach((h, i) => {
      if (!h.id) h.id = `section-${i}`;
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent;
      li.appendChild(a);
      toc.appendChild(li);
    });
  } else if (toc) {
    toc.closest('.article-sidebar__widget').style.display = 'none';
  }
</script>
