---
import { SITE, NAV_LINKS } from '../../config';
import { url } from '../../utils/url';
---

<footer class="footer">
  <div class="container footer__inner">

    <!-- Top row -->
    <div class="footer__top">
      <!-- Brand -->
      <div class="footer__brand">
        <a href={url('/')} class="footer__brand-link" aria-label={SITE.name}>
          <span class="footer__brand-icon">EI</span>
          <span class="footer__brand-name">{SITE.name}</span>
        </a>
        <p class="footer__tagline">{SITE.tagline}</p>
      </div>

      <!-- Navigation -->
      <nav class="footer__nav" aria-label="Navigacija v nogi">
        <p class="footer__nav-title">Strani</p>
        <ul class="footer__nav-links">
          {NAV_LINKS.map((link) => (
            <li><a href={url(link.href)} class="footer__nav-link">{link.label}</a></li>
          ))}
          <li><a href={url('/knjiznica')} class="footer__nav-link">Knjižnica</a></li>
        </ul>
      </nav>

      <!-- Social -->
      <div class="footer__social">
        <p class="footer__nav-title">Sledi</p>
        <a
          href={SITE.twitterUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="footer__social-link"
          aria-label="X / Twitter"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          X / Twitter
        </a>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="footer__disclaimer">
      <p>
        <strong>Zavrnitev odgovornosti:</strong> Vsebina na tej strani ni finančni nasvet in ni priporočilo za nakup ali prodajo finančnih instrumentov. Vse analize in komentarji so izključno izobraževalne narave. Investiranje vključuje tveganje izgube kapitala. Pred kakršno koli finančno odločitvijo se posvetujte s pooblaščenim finančnim svetovalcem.
      </p>
    </div>

    <!-- Bottom row -->
    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {new Date().getFullYear()} {SITE.name}. Vse pravice pridržane.
      </p>
      <p class="footer__made">
        Narejeno z ❤ za slovensko investitorsko skupnost
      </p>
    </div>

  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    background-color: var(--color-surface);
    margin-top: var(--space-3xl);
  }

  .footer__inner {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-xl);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-2xl);
    margin-bottom: var(--space-2xl);
  }

  /* Brand */
  .footer__brand-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    margin-bottom: var(--space-md);
  }

  .footer__brand-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--color-accent);
    color: white;
    border-radius: var(--radius-sm);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .footer__brand-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 280px;
  }

  /* Nav */
  .footer__nav-title {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-md);
  }

  .footer__nav-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer__nav-link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__nav-link:hover {
    color: var(--color-text);
  }

  /* Social */
  .footer__social-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__social-link:hover {
    color: var(--color-text);
  }

  /* Disclaimer */
  .footer__disclaimer {
    background: var(--color-surface-hover);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .footer__disclaimer p {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .footer__disclaimer strong {
    color: var(--color-text);
    font-weight: 600;
  }

  /* Bottom */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .footer__copyright,
  .footer__made {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .footer__bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
