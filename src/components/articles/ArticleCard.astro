---
import Badge from '../ui/Badge.astro';
import { url } from '../../utils/url';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  readingTime: number;
  category: string;
  slug: string;
  premium?: boolean;
  featured?: boolean;
}

const {
  title,
  description,
  pubDate,
  readingTime,
  category,
  slug,
  premium = false,
  featured = false,
} = Astro.props;

const formattedDate = new Intl.DateTimeFormat('sl-SI', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(pubDate);
---

<article class={`article-card ${featured ? 'article-card--featured' : ''}`}>
  <a href={url(`/analize/${slug}`)} class="article-card__link" aria-label={`Preberi: ${title}`}>
    <div class="article-card__meta-top">
      <Badge category={category} size="sm" />
      {premium && (
        <span class="article-card__premium-badge">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          Premium
        </span>
      )}
    </div>

    <h3 class="article-card__title">{title}</h3>
    <p class="article-card__description">{description}</p>

    <div class="article-card__meta-bottom">
      <time class="article-card__date" datetime={pubDate.toISOString()}>
        {formattedDate}
      </time>
      <span class="article-card__meta-divider" aria-hidden="true">·</span>
      <span class="article-card__reading-time">{readingTime} min branja</span>
    </div>

    <span class="article-card__cta" aria-hidden="true">
      Preberi
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </span>
  </a>
</article>

<style>
  .article-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }

  .article-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
    border-color: var(--color-border-strong);
  }

  .article-card--featured {
    border-color: var(--color-accent-border);
    background: linear-gradient(to bottom right, var(--color-surface), var(--color-accent-bg));
  }

  .article-card__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-xl);
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .article-card__meta-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .article-card__premium-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 600;
    color: #D97706;
    background: #FFF7ED;
    border-radius: var(--radius-full);
    padding: 2px 8px;
  }

  [data-theme="dark"] .article-card__premium-badge {
    background: #2A1800;
    color: #FDBA74;
  }

  .article-card__title {
    font-size: var(--text-lg);
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .article-card:hover .article-card__title {
    color: var(--color-accent);
  }

  .article-card__description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .article-card__meta-bottom {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .article-card__date,
  .article-card__reading-time {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  .article-card__meta-divider {
    color: var(--color-text-subtle);
    font-size: var(--text-xs);
  }

  .article-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    margin-top: auto;
    transition: gap var(--transition-fast);
  }

  .article-card:hover .article-card__cta {
    gap: 8px;
  }
</style>
