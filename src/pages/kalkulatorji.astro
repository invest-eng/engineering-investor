---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils/url';

const kalkulatorji = [
  {
    href: '/kalkulator-nalozb',
    emoji: '📊',
    title: 'Kalkulator naložb',
    subtitle: 'S&P 500 · Nepremičnine · Zlato · BTC · Banka',
    description:
      'Primerjaj 8 naložbenih razredov z grafom rasti, davki ZDoh-2, stroškovno razčlembo in osebno oceno primernosti za tvoj profil.',
    tags: ['DCA', 'Enkratni vložek', 'Graf rasti', 'ZDoh-2', 'Suitability score'],
    badge: 'Novo',
    badgeColor: 'accent',
  },
  {
    href: '/kalkulator',
    emoji: '🏦',
    title: 'INR vs IBKR Kalkulator',
    subtitle: 'Ilirika INR · Interactive Brokers',
    description:
      'Natančna primerjava med slovenskim naložbenim računom (INR) in IBKR z FIFO izračunom davkov, vsemi stroški po uradnem ceniku Ilirike in validacijo INR limitov.',
    tags: ['FIFO davki', 'INR limiti', 'Stroški Ilirika', 'ETF primerjava'],
    badge: null,
    badgeColor: null,
  },
  {
    href: '/kalkulator-neto-vrednosti',
    emoji: '💰',
    title: 'Kalkulator neto vrednosti',
    subtitle: 'Sredstva − Obveznosti · Likvidnost',
    description:
      'Vnesi svoja sredstva (gotovina, naložbe, nepremičnine, II./III. steber) in obveznosti (krediti, kartice). Dobiš neto vrednost, razmerje dolga in graf strukture premoženja.',
    tags: ['Neto vrednost', 'Likvidnost', 'Razmerje dolga', 'Lokalno shranjeno'],
    badge: 'Novo',
    badgeColor: 'accent',
  },
];
---

<BaseLayout
  title="Kalkulatorji"
  description="Finančni kalkulatorji za slovenskega vlagatelja — primerjava naložb, INR vs IBKR, davki ZDoh-2 in več."
>
  <div class="kalkulatorji-page">
    <div class="container">

      <header class="kalkulatorji-header fade-in">
        <div class="kalkulatorji-icon" aria-hidden="true">🧮</div>
        <h1 class="kalkulatorji-title">Kalkulatorji</h1>
        <p class="kalkulatorji-subtitle">
          Orodja za slovenskega vlagatelja — z davki, stroški in realnimi podatki.
        </p>
      </header>

      <div class="kalkulatorji-grid fade-in">
        {kalkulatorji.map((k) => (
          <a href={url(k.href)} class="kalkulator-card">
            <div class="kalkulator-card__top">
              <div class="kalkulator-card__emoji" aria-hidden="true">{k.emoji}</div>
              {k.badge && (
                <span class={`kalkulator-card__badge kalkulator-card__badge--${k.badgeColor}`}>
                  {k.badge}
                </span>
              )}
            </div>
            <h2 class="kalkulator-card__title">{k.title}</h2>
            <p class="kalkulator-card__subtitle">{k.subtitle}</p>
            <p class="kalkulator-card__desc">{k.description}</p>
            <div class="kalkulator-card__tags">
              {k.tags.map((tag) => (
                <span class="kalkulator-card__tag">{tag}</span>
              ))}
            </div>
            <div class="kalkulator-card__cta">
              Odpri kalkulator →
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .kalkulatorji-page {
    padding: var(--space-3xl) 0 var(--space-2xl);
    min-height: 70vh;
  }

  .kalkulatorji-header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto var(--space-2xl);
  }

  .kalkulatorji-icon {
    font-size: 2.75rem;
    margin-bottom: var(--space-lg);
  }

  .kalkulatorji-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-md);
  }

  .kalkulatorji-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .kalkulatorji-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-lg);
    max-width: 860px;
    margin: 0 auto;
  }

  .kalkulator-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-xl);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-base), box-shadow var(--transition-base), transform var(--transition-base);
  }

  .kalkulator-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
  }

  .kalkulator-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: var(--space-xs);
  }

  .kalkulator-card__emoji {
    font-size: 2.25rem;
    line-height: 1;
  }

  .kalkulator-card__badge {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 10px;
    border-radius: var(--radius-full);
  }

  .kalkulator-card__badge--accent {
    color: var(--color-accent);
    background: var(--color-accent-bg);
    border: 1px solid var(--color-accent-border);
  }

  .kalkulator-card__title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .kalkulator-card__subtitle {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    margin: 0;
  }

  .kalkulator-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: var(--space-xs) 0 0;
    flex: 1;
  }

  .kalkulator-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-md);
  }

  .kalkulator-card__tag {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-subtle);
    background: var(--color-surface-hover);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 2px 8px;
  }

  .kalkulator-card__cta {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    margin-top: var(--space-md);
  }

  @media (max-width: 600px) {
    .kalkulatorji-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
