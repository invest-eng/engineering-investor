---
import BaseLayout from '../layouts/BaseLayout.astro';
import Disclaimer from '../components/ui/Disclaimer.astro';
import Button from '../components/ui/Button.astro';
import { SITE } from '../config';
---

<BaseLayout
  title="O meni"
  description="Spoznaj Engineering Investor — projekt za finančno izobraževanje slovenskega občinstva skozi razlago aktualnih dogodkov."
>
  <div class="about-page">
    <div class="container">

      <div class="about-layout">
        <div class="about-main">

          <!-- Header -->
          <header class="about-header fade-in">
            <div class="about-header__avatar" aria-hidden="true">EI</div>
            <h1 class="about-header__name">{SITE.name}</h1>
            <p class="about-header__tagline">Finančno izobraževanje skozi aktualne dogodke</p>
          </header>

          <!-- Mission -->
          <section class="about-section fade-in">
            <h2 class="about-section__title">Zakaj Engineering Investor?</h2>
            <div class="about-section__content">
              <p>
                Vsakič ko sem poskušal slediti globalnemu finančnemu dogajanju, sem naletel na isto oviro:
                <strong>preveč informacij, premalo konteksta.</strong>
              </p>
              <p>
                Angleški viri so odlični — ampak jih moraš znati filtrirati. Vedeti moraš, kateri so
                resnično relevantni, kateri so clickbait in — kar je najpomembneje — <em>kako so medsebojno
                povezani.</em> Kaj to novica o Fed-u pomeni za bitcoin? Zakaj kitajska deflacija vpliva
                na DAX? Zakaj raste zlato, ko bi pričakoval nasprotno?
              </p>
              <p>
                Engineering Investor je moj odgovor na to. <strong>Filter, kontekst in razlaga</strong> —
                v slovenščini, za vsakogar, ki želi razumeti, kaj se dogaja in zakaj.
              </p>
            </div>
          </section>

          <!-- Approach -->
          <section class="about-section fade-in">
            <h2 class="about-section__title">Moj pristop</h2>
            <div class="about-section__content">
              <p>Vsaka analiza sledi jasni strukturi:</p>
              <ol class="about-list about-list--ordered">
                <li><strong>Kaj se je zgodilo</strong> — brez fluffа, samo dejstva</li>
                <li><strong>Zakaj je to pomembno</strong> — geopolitični, ekonomski ali tržni kontekst</li>
                <li><strong>Vpliv na trge</strong> — delnice, obveznice, valute, surovine, Bitcoin</li>
                <li><strong>Kaj se naučimo</strong> — prenosljivo znanje za prihodnje razumevanje</li>
              </ol>
              <p>
                Cilj ni predvideti prihodnost — nihče tega ne zmore zanesljivo. Cilj je
                <strong>razumeti sedanjost</strong> in zgraditi mentalne modele, ki nam pomagajo
                bolje interpretirati prihodnje dogodke.
              </p>
            </div>
          </section>

          <!-- Values -->
          <section class="about-section fade-in">
            <h2 class="about-section__title">Vrednote projekta</h2>
            <div class="about-values">
              {[
                { label: 'Jasnost', desc: 'Brez žargona brez razlage. Kompleksnost razgradim do razumljive ravni.' },
                { label: 'Poštenost', desc: 'Ne vem vsega. Ko so stvari negotove, to povem. Brez pretiranega zaupanja v lastne napovedi.' },
                { label: 'Kontekst', desc: 'Novica brez konteksta je šum. Vedno razložim, zakaj je nekaj važno — ne samo da je.' },
                { label: 'Brez hype-a', desc: 'Ni get-rich-quick. Ni kripto guru. Ni "ta delnica bo eksplodirala". Samo analiza in razlaga.' },
              ].map((v) => (
                <div class="about-value">
                  <span class="about-value__label">{v.label}</span>
                  <span class="about-value__desc">{v.desc}</span>
                </div>
              ))}
            </div>
          </section>

          <!-- What I'm not -->
          <section class="about-section fade-in">
            <h2 class="about-section__title">Kar nisem</h2>
            <div class="about-section__content">
              <p>
                Nisem licenciran finančni svetovalec, borzni posrednik ali upravljavec premoženja.
                <strong>Nič na tej strani ni finančni nasvet.</strong> Nikoli ne bom rekel "kupi to"
                ali "prodaj ono". To ni namen tega projekta in presega mojo vlogo.
              </p>
              <p>
                Sem nekdo, ki ga finance resnično zanimajo, ki se jih aktivno uči in ki želi to
                znanje deliti z drugimi — na razumljiv in pošten način.
              </p>
            </div>
          </section>

          <!-- CTA -->
          <div class="about-cta fade-in">
            <p class="about-cta__text">Sledi za redne analize in kratke komentarje:</p>
            <Button href={SITE.twitterUrl} variant="secondary" size="md" external={true}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              Sledi na X
            </Button>
          </div>

          <div style="margin-top: var(--space-xl);">
            <Disclaimer />
          </div>

        </div>

        <!-- Sidebar -->
        <aside class="about-sidebar fade-in">
          <div class="about-sidebar__card">
            <h3 class="about-sidebar__card-title">Hitro o projektu</h3>
            <ul class="about-sidebar__facts">
              {[
                { label: 'Jezik', value: 'Slovenščina' },
                { label: 'Format', value: 'Poglobljene analize' },
                { label: 'Frekvenca', value: '4–8x mesečno' },
                { label: 'Kategorije', value: 'Makro, Geo, Trgi, Bitcoin, Delnice' },
                { label: 'Finančni nasveti', value: 'Nikoli' },
              ].map((f) => (
                <li class="about-sidebar__fact">
                  <span class="about-sidebar__fact-label">{f.label}</span>
                  <span class="about-sidebar__fact-value">{f.value}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="about-sidebar__card about-sidebar__card--accent">
            <h3 class="about-sidebar__card-title">Začni brati</h3>
            <p class="about-sidebar__card-desc">
              Oglej si zadnje analize in preizkusi, ali ti pristop ustreza.
            </p>
            <Button href="/analize" size="sm">
              Preberi analize →
            </Button>
          </div>
        </aside>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  .about-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-2xl);
    align-items: start;
  }

  /* Header */
  .about-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }

  .about-header__avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: var(--color-accent);
    color: white;
    border-radius: var(--radius-md);
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  .about-header__name {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .about-header__tagline {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  /* Sections */
  .about-section {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }

  .about-section:last-of-type {
    border-bottom: none;
  }

  .about-section__title {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-lg);
  }

  .about-section__content p {
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: 1.8;
    margin-bottom: var(--space-md);
  }

  .about-section__content p:last-child {
    margin-bottom: 0;
  }

  .about-list--ordered {
    list-style: decimal;
    padding-left: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin: var(--space-md) 0;
  }

  .about-list--ordered li {
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: 1.6;
  }

  /* Values */
  .about-values {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .about-value {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: var(--space-lg);
    align-items: start;
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .about-value:last-child {
    border-bottom: none;
  }

  .about-value__label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .about-value__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* CTA */
  .about-cta {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .about-cta__text {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Sidebar */
  .about-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + var(--space-xl));
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .about-sidebar__card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }

  .about-sidebar__card--accent {
    background: var(--color-accent-bg);
    border-color: var(--color-accent-border);
  }

  .about-sidebar__card-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: var(--space-md);
  }

  .about-sidebar__card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .about-sidebar__facts {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .about-sidebar__fact {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-border);
    gap: var(--space-sm);
  }

  .about-sidebar__fact:last-child {
    border-bottom: none;
  }

  .about-sidebar__fact-label {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  .about-sidebar__fact-value {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text);
    text-align: right;
  }

  @media (max-width: 1024px) {
    .about-layout {
      grid-template-columns: 1fr;
    }

    .about-sidebar {
      position: static;
      order: -1;
    }
  }
</style>
