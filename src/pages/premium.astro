---
import BaseLayout from '../layouts/BaseLayout.astro';
import Disclaimer from '../components/ui/Disclaimer.astro';
import Badge from '../components/ui/Badge.astro';

const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: 'Poglobljene analize',
    desc: 'Daljši, bolj detajlni breakdown članki z več konteksta, podatkov in primerjav.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
    title: 'Tedenski povzetki',
    desc: 'Vsak teden strukturiran pregled najpomembnejših makro in tržnih dogajanj.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: 'Tržni razredi v kontekstu',
    desc: 'Vsak makro razvoj razložen skozi prizmo delnic, obveznic, valut, zlata in Bitcoina.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>`,
    title: 'Zgodnji dostop',
    desc: 'Nekateri premium članki dostopni 48h pred brezplačno objavo.',
  },
];

const lockedPreviews = [
  {
    category: 'Makro',
    title: 'Fed vs. ECB: divergenca monetarne politike in kaj to pomeni za EUR/USD',
    desc: 'Celovita primerjalna analiza pristopa ameriške in evropske centralne banke ter implikacije za evropske vlagatelje.',
    readingTime: 12,
  },
  {
    category: 'Geopolitika',
    title: 'Bližnjevzhodni konflikt in nafta: zakaj cena ostaja pod 90 USD',
    desc: 'Razlaga, zakaj geopolitična napetost tokrat ni "prevajala" v cene nafte in kaj to pove o ponudbi in povpraševanju.',
    readingTime: 10,
  },
  {
    category: 'Delnice',
    title: 'Vrednostne vs. rastne delnice: katera strategija zmaga pri visokih obrestih',
    desc: 'Analiza historičnih podatkov in razlaga, zakaj so obrestne mere tako ključni dejavnik pri vrednotenju.',
    readingTime: 11,
  },
];
---

<BaseLayout
  title="Premium"
  description="Poglobljene analize, tedenski povzetki in ekskluzivna vsebina za resne finančne navdušence."
>
  <div class="premium-page">
    <div class="container">

      <!-- Hero -->
      <header class="premium-hero fade-in">
        <div class="premium-hero__label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          Engineering Investor Premium
        </div>
        <h1 class="premium-hero__title">
          Več konteksta.<br />Bolj poglobljeno.
        </h1>
        <p class="premium-hero__subtitle">
          Za tiste, ki želijo iti globlje od povprečne novice.
          Premium vsebina prinaša strukturirane analize, tedenski pregled dogajanja
          in ekskluzivne breakdown članke — vse v slovenščini.
        </p>
        <p class="premium-hero__disclaimer">
          Vse vsebine so izključno izobraževalne narave. Nič ni finančni nasvet.
        </p>
      </header>

      <!-- Features -->
      <section class="premium-features fade-in">
        <h2 class="premium-features__title">Kaj dobiš</h2>
        <div class="premium-features__grid">
          {features.map((f) => (
            <div class="feature-card">
              <div class="feature-card__icon" set:html={f.icon} />
              <h3 class="feature-card__title">{f.title}</h3>
              <p class="feature-card__desc">{f.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Locked previews -->
      <section class="premium-previews fade-in">
        <h2 class="premium-previews__title">Primeri premium vsebin</h2>
        <p class="premium-previews__subtitle">Pokukaj v to, kar te čaka.</p>
        <div class="premium-previews__grid">
          {lockedPreviews.map((item) => (
            <div class="locked-card">
              <div class="locked-card__meta">
                <Badge category={item.category} size="sm" />
                <span class="locked-card__time">{item.readingTime} min</span>
              </div>
              <h3 class="locked-card__title">{item.title}</h3>
              <p class="locked-card__desc">{item.desc}</p>
              <div class="locked-card__lock" aria-label="Zaklenjeno — na voljo s premium naročnino">
                <div class="locked-card__lock-overlay">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                  </svg>
                  <span>Premium vsebina</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Pricing -->
      <section class="premium-pricing fade-in">
        <div class="pricing-card">
          <div class="pricing-card__header">
            <div class="pricing-card__badge">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              Premium
            </div>
            <div class="pricing-card__price">
              <span class="pricing-card__amount">€9</span>
              <span class="pricing-card__period">/ mesec</span>
            </div>
            <p class="pricing-card__desc">
              Dostop do vseh premium vsebin, tedenskih povzetkov in globokih analiz.
            </p>
          </div>

          <ul class="pricing-card__features">
            {[
              'Vse brezplačne analize',
              'Poglobljene premium analize',
              'Tedenski tržni povzetek',
              'Zgodnji dostop do novih vsebin',
              'Brez oglasov',
              'Podpora razvoju projekta',
            ].map((feat) => (
              <li class="pricing-card__feature">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {feat}
              </li>
            ))}
          </ul>

          <div class="pricing-card__cta">
            <button class="pricing-card__btn" type="button" disabled>
              Kmalu na voljo
            </button>
            <p class="pricing-card__note">
              Plačilni sistem je v pripravi. Pustite email na domači strani in vas obvestimo.
            </p>
          </div>
        </div>
      </section>

      <div style="margin-top: var(--space-2xl);">
        <Disclaimer />
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .premium-page {
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  /* Hero */
  .premium-hero {
    max-width: 640px;
    margin-bottom: var(--space-3xl);
  }

  .premium-hero__label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    font-weight: 600;
    color: #D97706;
    background: #FFF7ED;
    border: 1px solid #FDE68A;
    border-radius: var(--radius-full);
    padding: 4px 14px;
    margin-bottom: var(--space-xl);
  }

  [data-theme="dark"] .premium-hero__label {
    background: #2A1800;
    color: #FDBA74;
    border-color: #92400E;
  }

  .premium-hero__title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-lg);
  }

  .premium-hero__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .premium-hero__disclaimer {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    font-style: italic;
  }

  /* Features */
  .premium-features {
    margin-bottom: var(--space-3xl);
  }

  .premium-features__title {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-xl);
  }

  .premium-features__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .feature-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--color-accent-bg);
    border: 1px solid var(--color-accent-border);
    border-radius: var(--radius-md);
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .feature-card__title {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .feature-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* Previews */
  .premium-previews {
    margin-bottom: var(--space-3xl);
  }

  .premium-previews__title {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
  }

  .premium-previews__subtitle {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .premium-previews__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  /* Locked card */
  .locked-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    position: relative;
    overflow: hidden;
  }

  .locked-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-md);
  }

  .locked-card__time {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  .locked-card__title {
    font-size: var(--text-base);
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: var(--space-sm);
    filter: blur(3px);
    user-select: none;
  }

  .locked-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    filter: blur(4px);
    user-select: none;
  }

  .locked-card__lock {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(to bottom, transparent 0%, var(--color-surface) 50%);
  }

  .locked-card__lock-overlay {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md) var(--space-lg);
    box-shadow: var(--shadow-md);
  }

  .locked-card__lock-overlay span {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .locked-card__lock-overlay svg {
    color: var(--color-text-muted);
  }

  /* Pricing */
  .premium-pricing {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-2xl);
  }

  .pricing-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    max-width: 420px;
    width: 100%;
  }

  .pricing-card__header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .pricing-card__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-xs);
    font-weight: 600;
    color: #D97706;
    background: #FFF7ED;
    border-radius: var(--radius-full);
    padding: 3px 10px;
    margin-bottom: var(--space-lg);
  }

  [data-theme="dark"] .pricing-card__badge {
    background: #2A1800;
    color: #FDBA74;
  }

  .pricing-card__price {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .pricing-card__amount {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--color-text);
  }

  .pricing-card__period {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .pricing-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .pricing-card__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .pricing-card__feature {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .pricing-card__feature svg {
    color: var(--color-success);
    flex-shrink: 0;
  }

  .pricing-card__cta {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .pricing-card__btn {
    width: 100%;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    color: white;
    background: var(--color-accent);
    border: none;
    border-radius: var(--radius-sm);
    padding: 0.75rem 1.5rem;
    cursor: not-allowed;
    opacity: 0.6;
    transition: background-color var(--transition-fast);
  }

  .pricing-card__note {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    text-align: center;
    line-height: 1.6;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .premium-features__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .premium-previews__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .premium-features__grid,
    .premium-previews__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
