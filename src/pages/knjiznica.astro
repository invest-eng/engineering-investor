---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import { url } from '../utils/url';
---

<BaseLayout
  title="Knjižnica"
  description="Priporočene knjige, viri in orodja za razumevanje financ, ekonomije in investiranja."
>
  <div class="knjiznica-page">
    <div class="container">
      <div class="knjiznica-coming-soon fade-in">

        <div class="knjiznica-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
          </svg>
        </div>

        <h1 class="knjiznica-title">Knjižnica</h1>
        <p class="knjiznica-subtitle">
          Priporočene knjige, resursi in orodja za boljše razumevanje financ in investiranja.
          Sekcija je v pripravi.
        </p>

        <div class="knjiznica-badge">Kmalu</div>

        <p class="knjiznica-teaser">
          V knjižnici bodo:
        </p>
        <ul class="knjiznica-list">
          <li>Priporočene knjige o makroekonomiji, investiranju in geopolitiki</li>
          <li>Koristni viri za sledenje trgom (brezplačni in plačljivi)</li>
          <li>Orodja za analizo (screenerji, kalkulatorji, grafi)</li>
          <li>Glosarij finančnih izrazov v slovenščini</li>
        </ul>

        <div class="knjiznica-cta">
          <Button href={url('/analize')}>
            Medtem pa: preberi analize →
          </Button>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .knjiznica-page {
    padding: var(--space-3xl) 0;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .knjiznica-coming-soon {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .knjiznica-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    background: var(--color-accent-bg);
    border: 1px solid var(--color-accent-border);
    border-radius: var(--radius-lg);
    color: var(--color-accent);
    margin: 0 auto var(--space-xl);
  }

  .knjiznica-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-md);
  }

  .knjiznica-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }

  .knjiznica-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    background: var(--color-accent-bg);
    border: 1px solid var(--color-accent-border);
    border-radius: var(--radius-full);
    padding: 4px 14px;
    margin-bottom: var(--space-xl);
  }

  .knjiznica-teaser {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    text-align: left;
  }

  .knjiznica-list {
    list-style: none;
    text-align: left;
    margin-bottom: var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .knjiznica-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .knjiznica-list li::before {
    content: '→';
    color: var(--color-accent);
    flex-shrink: 0;
    font-size: var(--text-sm);
  }

  .knjiznica-cta {
    display: flex;
    justify-content: center;
  }
</style>
