# Engineering Investor — environment variables
#
# Copy this file to `.env` and fill in the values.
# `.env` is gitignored — never commit it.
#
# For production: add the same variables to GitHub Secrets
# (Settings → Secrets and variables → Actions → New repository secret).

# --- Supabase (required for login + tracker cloud sync) ---
# Get these from https://supabase.com/dashboard → your project → Settings → API
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...
